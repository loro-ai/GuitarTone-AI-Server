{
  "name": "@guitartone/api",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "main": "./src/_core/index.ts",
  "exports": {
    ".": "./src/_core/index.ts",
    "./routers": "./src/routers.ts"
  },
  "scripts": {
    "dev": "NODE_ENV=development tsx watch src/_core/index.ts",
    "build": "esbuild src/_core/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "NODE_ENV=production node dist/index.js",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@trpc/server": "^11.6.0",
    "axios": "^1.12.0",
    "bcryptjs": "^3.0.3",
    "cookie": "^1.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "express": "^4.21.2",
    "jose": "6.1.0",
    "mongoose": "^9.3.0",
    "nanoid": "^5.1.5",
    "openai": "^4.67.0",
    "superjson": "^1.13.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "4.17.21",
    "@types/node": "^24.7.0",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.1",
    "typescript": "5.9.3"
  }
}
